PORT=4000
MONGO_URI=mongodb://localhost:27017/scts
JWT_SECRET=replace_me_with_secure_secret
CAPTCHA_SECRET=replace_me_with_another_secure_secret
JWT_EXPIRES_IN=7d
STUDENT_TOKEN_EXPIRES=7d

# Email OTP (SendGrid) — leave SENDGRID_API_KEY unset in local dev to fall back
# to console-logged OTPs and a debugOtp field in API responses.
SENDGRID_API_KEY=
SENDGRID_FROM=no-reply@madnir.com
SUPPORT_EMAIL=support@madnir.com
BRAND_NAME=Madnir

# Razorpay (admin/school subscription payments). Leaving these blank keeps
# the payment flow in demo mode (no real charge, order IDs are simulated).
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Cloudinary (complaint physical-damage photos). All three values are required
# in production. Local-disk fallback is development-only.
# Alternatively, provide CLOUDINARY_URL instead of the three individual values.
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
PUBLIC_BASE_URL=http://localhost:4000

# AI-assisted bulk student import column mapping, via a locally-running model
# server with an OpenAI-compatible API — Ollama (default, localhost:11434) or
# LM Studio (localhost:1234) both work. Pull a small model first, e.g.:
#   ollama pull llama3.2
# Leave as default / unreachable to fall back to rule-based header matching.
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
LOCAL_LLM_MODEL=llama3.2
